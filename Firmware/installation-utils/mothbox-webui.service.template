[Unit]
Description=Mothbox Web UI Server
After=network.target

[Service]
Type=simple
User=__MOTHBOX_USER__
Group=gpio
WorkingDirectory=__MOTHBOX_HOME__/webui/backend
ExecStart=/usr/bin/python3 __MOTHBOX_HOME__/webui/backend/app.py
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

# Environment variables
Environment="MOTHBOX_HOME=__MOTHBOX_HOME__"
Environment="PYTHONUNBUFFERED=1"

[Install]
WantedBy=multi-user.target
