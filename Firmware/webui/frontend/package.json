{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "comments": {
    "react-window": "Chosen for VirtualPhotoGrid virtualization. NOT deprecated, zero CVEs as of 2025-01. TanStack Virtual was evaluated but rejected due to: (1) react-window's FixedSizeGrid API is purpose-built for grid virtualization, (2) TanStack requires manual 2D virtualization with more complex implementation, (3) Migration would require 15-20 hours with high regression risk for minimal benefit. Decision should be revisited only if react-window is officially deprecated or if specific TanStack Virtual features are needed. Last verified: 2025-01"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:ci": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
