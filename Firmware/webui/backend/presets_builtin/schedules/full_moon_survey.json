          "action_name": "takephoto",
          "offset_minutes": 5,
          "parameters": {},
          "description": "First capture at 5 minutes"
        },
        {
          "action_type": "camera",
          "action_name": "takephoto",
          "offset_minutes": 15,
          "parameters": {},
          "description": "Second capture at 15 minutes"
        },
        {
